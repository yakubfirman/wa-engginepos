{
  "name": "wa-engine",
  "productName": "WA Engine",
  "version": "1.0.0",
  "description": "WhatsApp Engine untuk GreenPOS - Kirim struk via WhatsApp",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:all": "npm run build && npm run build:electron",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build:all && electron-builder --win",
    "electron:start": "electron .",
    "server:dev": "npx ts-node server/index.ts",
    "preview": "vite preview"
  },
  "keywords": [
    "whatsapp",
    "greenpos",
    "electron"
  ],
  "author": {
    "name": "Yakub Firman Mustofa",
    "email": "yakubfirman@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "@adiwajshing/baileys": "^5.0.0",
    "@electron/remote": "^2.1.2",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "electron-store": "^8.2.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "libphonenumber-js": "^1.12.19",
    "lucide-react": "^0.511.0",
    "pino": "^9.7.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^11.1.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.3",
    "vite": "^6.2.2",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.3"
  }
}
